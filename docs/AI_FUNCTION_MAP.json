{
  "schemaVersion": 1,
  "project": {
    "name": "Eltronic",
    "repo": "JakeG-42/eltronic",
    "framework": "Next.js App Router",
    "productionUrl": "https://project-5v5cr.vercel.app",
    "adminUrl": "https://project-5v5cr.vercel.app/studio",
    "vercelProject": "project-5v5cr"
  },
  "agentInstructions": {
    "readFirst": [
      "docs/AGENT_CONTEXT.md",
      "docs/AI_FUNCTION_MAP.json",
      "docs/SITE_FUNCTIONS.md",
      "docs/PROJECT_LOG.md"
    ],
    "verifyBeforeChanging": [
      "src/lib/admin-auth.ts",
      "src/lib/managed-data.ts",
      "src/app/studio/actions.ts",
      "src/app/studio/(admin)/layout.tsx",
      "src/app/studio/(admin)/products/page.tsx",
      "src/components/studio/product-form.tsx"
    ],
    "updateWhenChanged": [
      "docs/AI_FUNCTION_MAP.json",
      "docs/AGENT_CONTEXT.md",
      "docs/SITE_FUNCTIONS.md",
      "docs/PROJECT_LOG.md"
    ]
  },
  "auth": {
    "id": "studio-single-admin-cookie-auth",
    "purpose": "Protect the Eltronic Studio admin area and server actions.",
    "temporaryCredentials": {
      "username": "admin",
      "password": "password",
      "securityNote": "Temporary testing defaults only. Override with environment variables before wider sharing."
    },
    "env": {
      "username": "ELTRONIC_ADMIN_USERNAME",
      "password": "ELTRONIC_ADMIN_PASSWORD",
      "secret": "ELTRONIC_ADMIN_SECRET",
      "fallbackSecret": "temporary-eltronic-admin-secret"
    },
    "files": {
      "authUtility": "src/lib/admin-auth.ts",
      "loginPage": "src/app/studio/login/page.tsx",
      "loginAction": "src/app/studio/login/actions.ts",
      "adminGuards": "src/app/studio/(admin)/layout.tsx"
    },
    "functions": {
      "verify": "verifyAdminCredentials(username, password)",
      "createSession": "setAdminSession()",
      "destroySession": "clearAdminSession()",
      "guard": "isAdminAuthenticated()"
    },
    "session": {
      "cookieName": "eltronic_admin_session",
      "valueShape": "<issuedAt>.<signature>",
      "signature": "HMAC-SHA256(issuedAt, adminSecret)",
      "maxAgeSeconds": 604800,
      "flags": ["HttpOnly", "SameSite=Lax", "Secure in production"]
    },
    "futureExtension": {
      "testUsers": "Extend src/lib/admin-auth.ts with an AdminUser list/source, keep verifyAdminCredentials as the public API, and sign a user-aware session payload.",
      "roles": "Add role to session payload and expose getCurrentAdminUser() while keeping isAdminAuthenticated() for simple guards."
    }
  },
  "storage": {
    "id": "managed-data",
    "files": {
      "implementation": "src/lib/managed-data.ts",
      "seedProducts": "src/content/products.ts",
      "localFile": ".data/eltronic-data.json"
    },
    "selectionOrder": [
      {
        "mode": "Upstash/Vercel KV",
        "condition": "KV_REST_API_URL and KV_REST_API_TOKEN are present"
      },
      {
        "mode": "local JSON",
        "condition": "not production, or ELTRONIC_ALLOW_LOCAL_WRITES=true"
      },
      {
        "mode": "read-only fallback",
        "condition": "production without KV"
      }
    ],
    "env": {
      "kvUrl": ["KV_REST_API_URL", "UPSTASH_REDIS_REST_URL"],
      "kvToken": ["KV_REST_API_TOKEN", "UPSTASH_REDIS_REST_TOKEN"],
      "allowLocalProductionWrites": "ELTRONIC_ALLOW_LOCAL_WRITES"
    },
    "currentVercelEnvCheck": {
      "checkedAt": "2026-04-27",
      "project": "project-5v5cr",
      "result": "No environment variables configured"
    },
    "exports": [
      "getProducts",
      "getProductBySlug",
      "getProductFamilies",
      "getFeaturedProducts",
      "getProductImages",
      "upsertProduct",
      "deleteProduct",
      "getSubmissions",
      "createContactSubmission",
      "updateSubmissionStatus",
      "deleteSubmission",
      "productFromFormData"
    ]
  },
  "routes": [
    {
      "path": "/",
      "file": "src/app/(site)/page.tsx",
      "kind": "public",
      "dataSource": "getFeaturedProducts(), src/content/site.ts#serviceModules, workflowModules, sectorModules"
    },
    {
      "path": "/products",
      "file": "src/app/(site)/products/page.tsx",
      "kind": "public",
      "dataSource": "getProducts(), getProductFamilies()"
    },
    {
      "path": "/products/[slug]",
      "file": "src/app/(site)/products/[slug]/page.tsx",
      "kind": "public",
      "dataSource": "getProductBySlug(slug), getProductImages(product)",
      "clientComponents": ["src/components/site/product-media-gallery.tsx"]
    },
    {
      "path": "/solutions",
      "file": "src/app/(site)/solutions/page.tsx",
      "kind": "public-content",
      "dataSource": "src/content/site.ts#serviceModules, workflowModules"
    },
    {
      "path": "/software-it",
      "file": "src/app/(site)/software-it/page.tsx",
      "kind": "public-content",
      "dataSource": "src/content/site.ts#softwareServiceModules, softwareWorkflowModules"
    },
    {
      "path": "/sectors",
      "file": "src/app/(site)/sectors/page.tsx",
      "kind": "public-content",
      "dataSource": "src/content/site.ts#sectorModules"
    },
    {
      "path": "/data-specification",
      "file": "src/app/(site)/data-specification/page.tsx",
      "kind": "public-resource",
      "dataSource": "getProducts(), src/content/site.ts#resourceModules"
    },
    {
      "path": "/contact",
      "file": "src/app/(site)/contact/page.tsx",
      "kind": "public-form",
      "action": "src/app/contact/actions.ts#submitContactFormAction",
      "antiSpam": "src/lib/contact-captcha.ts local signed maths captcha plus hidden website honeypot"
    },
    {
      "path": "/studio/login",
      "file": "src/app/studio/login/page.tsx",
      "kind": "admin-login",
      "action": "src/app/studio/login/actions.ts#loginAction"
    },
    {
      "path": "/studio",
      "file": "src/app/studio/(admin)/page.tsx",
      "kind": "admin-dashboard",
      "guard": "isAdminAuthenticated()"
    },
    {
      "path": "/studio/products",
      "file": "src/app/studio/(admin)/products/page.tsx",
      "kind": "admin-products-table",
      "guard": "isAdminAuthenticated()",
      "quickEdit": "/studio/products?quick=<slug>"
    },
    {
      "path": "/studio/products/new",
      "file": "src/app/studio/(admin)/products/new/page.tsx",
      "kind": "admin-product-create",
      "guard": "isAdminAuthenticated()"
    },
    {
      "path": "/studio/products/[slug]/edit",
      "file": "src/app/studio/(admin)/products/[slug]/edit/page.tsx",
      "kind": "admin-product-edit",
      "guard": "isAdminAuthenticated()"
    },
    {
      "path": "/studio/submissions",
      "file": "src/app/studio/(admin)/submissions/page.tsx",
      "kind": "admin-submission-inbox",
      "guard": "isAdminAuthenticated()"
    },
    {
      "path": "/studio/settings",
      "file": "src/app/studio/(admin)/settings/page.tsx",
      "kind": "admin-settings",
      "guard": "isAdminAuthenticated()"
    }
  ],
  "serverActions": [
    {
      "id": "loginAction",
      "file": "src/app/studio/login/actions.ts",
      "authRequired": false,
      "effect": "Verifies admin credentials, sets session cookie, redirects to /studio."
    },
    {
      "id": "saveProductAction",
      "file": "src/app/studio/actions.ts",
      "authRequired": true,
      "effect": "Creates or updates one product from form data and revalidates managed pages."
    },
    {
      "id": "deleteProductAction",
      "file": "src/app/studio/actions.ts",
      "authRequired": true,
      "effect": "Deletes a product by slug and revalidates managed pages."
    },
    {
      "id": "updateSubmissionStatusAction",
      "file": "src/app/studio/actions.ts",
      "authRequired": true,
      "effect": "Updates one contact submission status."
    },
    {
      "id": "deleteSubmissionAction",
      "file": "src/app/studio/actions.ts",
      "authRequired": true,
      "effect": "Deletes one contact submission."
    },
    {
      "id": "logoutAction",
      "file": "src/app/studio/actions.ts",
      "authRequired": false,
      "effect": "Clears admin session cookie and redirects to login."
    },
    {
      "id": "submitContactFormAction",
      "file": "src/app/contact/actions.ts",
      "authRequired": false,
      "effect": "Validates public contact form input, verifies signed maths captcha and honeypot, stores a contact submission, redirects to success/error state."
    }
  ],
  "productModel": {
    "sourceType": "TypeScript",
    "typeFile": "src/content/products.ts",
    "templates": ["hmi", "data-logger", "module"],
    "fields": [
      "slug",
      "name",
      "category",
      "family",
      "template",
      "sourceUrl",
      "sku",
      "price",
      "tags[]",
      "modules.gallery",
      "modules.highlights",
      "modules.specifications",
      "modules.documents",
      "modules.variants",
      "modules.enquiry",
      "image.src",
      "image.alt",
      "images[].src",
      "images[].alt",
      "summary",
      "description",
      "highlights[]",
      "specifications[].label",
      "specifications[].value",
      "documents[].label",
      "documents[].url",
      "variants[].name",
      "variants[].sku",
      "variants[].price",
      "variants[].details",
      "variants[].articleNumber",
      "enquiryPrompt"
    ],
    "templateChangeChecklist": [
      "src/content/products.ts#ProductTemplate",
      "src/lib/managed-data.ts#parseProductTemplate",
      "src/components/studio/product-form.tsx template select",
      "src/app/(site)/products/[slug]/page.tsx#productTypeLabel",
      "docs/AI_FUNCTION_MAP.json",
      "docs/SITE_FUNCTIONS.md"
    ],
    "galleryImages": {
      "function": "src/lib/managed-data.ts#getProductImages",
      "behavior": "Returns managed product.images in order, or product.image as the single fallback. Placeholder gallery assets must be explicit seed/Studio image entries, not hidden fallback appends.",
      "seedPlaceholders": "public/product-images/placeholders/images-coming-soon-*.svg"
    },
    "primaryImageAssets": "public/product-images"
  },
  "contactSubmissionModel": {
    "typeFile": "src/lib/managed-data.ts",
    "typeName": "ContactSubmission",
    "antiSpam": "src/lib/contact-captcha.ts signs a short-lived math challenge; src/app/contact/actions.ts stores captcha failures and populated website honeypot values as blocked records when storage is available.",
    "tester": "npm run test:contact-bot runs scripts/test-contact-antispam.mjs against production by default and only exercises rejected bot paths unless -- --valid is passed.",
    "types": ["enquiry", "captcha_failed", "honeypot_spam"],
    "statuses": ["new", "reviewed", "replied", "archived", "blocked"],
    "fields": [
      "id",
      "name",
      "company",
      "email",
      "productSlug",
      "productName",
      "message",
      "status",
      "type",
      "rejectionReason",
      "source",
      "createdAt",
      "updatedAt"
    ],
    "emailNotification": "not implemented"
  },
  "ui": {
    "publicCss": "src/app/globals.css",
    "adminStyle": "Tailwind CSS v4 + local shadcn-style primitives",
    "shadcnConfig": "components.json",
    "publicShell": "src/components/site/site-shell.tsx",
    "publicAmbientBackground": {
      "file": "src/components/site/ambient-background.tsx",
      "styleFile": "src/app/globals.css",
      "behavior": "Public-only fixed ambient layer with low-opacity floating syntax glyphs. Respects prefers-reduced-motion; no cursor or pointer-follow glow."
    },
    "homeHeroTypewriter": {
      "file": "src/components/site/hero-role-typewriter.tsx",
      "styleFile": "src/app/globals.css",
      "behavior": "Client-side typewriter role label above the Eltronic homepage hero wordmark. Cycles through short professional role phrases and falls back for prefers-reduced-motion."
    },
    "publicNavIcons": {
      "file": "src/components/site/site-shell.tsx",
      "type": "inline SVG",
      "primaryItems": ["Products", "Solutions", "Software", "About", "Contact"],
      "secondaryItems": ["Sectors", "Data & specification in footer/page CTAs"],
      "mobileBehavior": "Full desktop nav collapses to a native details hamburger menu under the mobile breakpoint. src/components/site/mobile-nav-auto-close.tsx closes it on link click, outside tap and Escape."
    },
    "publicFooter": {
      "shellFile": "src/components/site/site-shell.tsx",
      "styleFile": "src/app/globals.css",
      "behavior": "Simple static public footer. Sticky/reveal behavior was removed after causing the footer to appear behind page content."
    },
    "publicWorkflowCopy": {
      "contentFile": "src/content/site.ts",
      "exports": ["workflowModules", "softwareWorkflowModules"],
      "tone": "Professional delivery for complex systems, presented as controlled, clear and easy for customers to move through. Prefer precise terms like specialist equipment, operating environment, application, platform, control system and operational workflow over repeated generic machine/machinery phrasing."
    },
    "productMediaGallery": {
      "file": "src/components/site/product-media-gallery.tsx",
      "behavior": "Client-side selected image state, thumbnail switching, touch swipe and desktop click-drag switching, keyboard-friendly zoom overlay, previous/next controls."
    },
    "publicTechnicalVisuals": {
      "file": "src/components/site/technical-visuals.tsx",
      "type": "code-native SVG",
      "variants": ["display", "network", "sectors", "data"]
    },
    "studioShell": "src/components/studio/studio-shell.tsx",
    "studioTheme": "dark/light mode stored in localStorage key eltronic-studio-theme",
    "studioPageHeaderPattern": "StudioShell topbar displays the active mode. Admin pages use compact .studio-page-header description/action rows instead of large duplicate page h1 titles.",
    "websiteBuilder": {
      "route": "/studio/builder",
      "defaults": "src/content/site-builder.ts",
      "storage": "siteBuilder key in src/lib/managed-data.ts",
      "action": "saveSiteBuilderAction in src/app/studio/actions.ts",
      "publicConsumer": "src/app/(site)/page.tsx",
      "behavior": "Protected internal Elementor/Colibri-style builder foundation. Controls homepage theme preset, colors, background style, visual density, hero copy/typewriter/CTAs/visual, and section visibility/order/copy. No public admin toolbar."
    },
    "templateFileEditor": {
      "route": "/studio/templates",
      "registry": "src/lib/template-editor.ts",
      "action": "saveTemplateFileAction in src/app/studio/actions.ts",
      "styleFile": "src/app/globals.css",
      "behavior": "Protected WordPress Theme File Editor-style source viewer/editor. Uses a whitelist of src files only. Saves are local-development-only; production/Vercel is read-only. next.config.ts traces src files for this route."
    },
    "classicWooStyleBackend": {
      "routes": ["/studio/classic/products", "/studio/classic/products/new", "/studio/classic/products/[slug]/edit"],
      "shell": "src/components/studio/studio-shell.tsx",
      "editor": "src/components/studio/classic/woocommerce-product-editor.tsx",
      "styleFile": "src/app/globals.css",
      "behavior": "Protected WordPress/WooCommerce-inspired backend. Existing Studio shows a Switch to new button. Classic shell has WP-like admin bar/menu, product list table, Screen Options/Help tabs, product data panels, publish box, taxonomy boxes, product image and product gallery boxes. Saves through existing saveProductAction."
    },
    "components": [
      "src/components/ui/button.tsx",
      "src/components/ui/card.tsx",
      "src/components/ui/input.tsx",
      "src/components/ui/textarea.tsx",
      "src/components/ui/label.tsx",
      "src/components/ui/badge.tsx",
      "src/components/ui/separator.tsx",
      "src/components/studio/product-form.tsx",
      "src/components/studio/product-image-manager.tsx",
      "src/components/studio/submission-card.tsx"
    ],
    "studioProductImageManager": {
      "file": "src/components/studio/product-image-manager.tsx",
      "parser": "src/lib/managed-data.ts#productFromFormData",
      "fields": ["imageSrc", "imageAlt"],
      "behavior": "Visual image preview and ordering UI. Repeated imageSrc/imageAlt fields are saved in order; first image becomes product.image. Product galleries should use managed images from this UI or seed data only."
    },
    "studioProductForm": {
      "file": "src/components/studio/product-form.tsx",
      "sections": ["Product data", "Inventory, pricing and tags", "Product modules", "Public copy", "Images and gallery", "Technical content", "Variables and variants"],
      "behavior": "WooCommerce-style two-column editor with collapsible details/summary sections. Main product fields sit left; publish, commerce and module controls sit in a sticky sidebar on desktop. Saves admin-only SKU, price, tags, module switches and enhanced variant rows without displaying them publicly yet."
    }
  },
  "deployment": {
    "productionCommand": "npx vercel --prod --yes",
    "buildCommand": "npm run build",
    "lintCommand": "npm run lint",
    "lastKnownProductionAlias": "https://project-5v5cr.vercel.app"
  }
}
